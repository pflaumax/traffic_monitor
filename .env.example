UPSTREAM_BASE_URL=https://httpbin.org

# kafka KRaft cluster ID generate with:
# python3 -c "import uuid, base64; print(base64.urlsafe_b64encode(uuid.uuid4().bytes).decode().rstrip('='))"
KAFKA_CLUSTER_ID=your-generated-id-here

KAFKA_BOOTSTRAP_SERVERS=kafka:9092

REDIS_URL=redis://redis:6379

# Rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=100

# Change these in production, use a long random secret for JWT_SECRET_KEY
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# JWT_SECRET_KEY=change-me-in-production-use-a-long-random-secret
# JWT_ALGORITHM=HS256
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin

# Kafka consumer tuning (override as needed)
# KAFKA_GROUP_ID=traffic-consumer-group
# KAFKA_AUTO_OFFSET_RESET=earliest
# KAFKA_SESSION_TIMEOUT_MS=10000
# KAFKA_HEARTBEAT_INTERVAL_MS=3000
# KAFKA_MAX_POLL_INTERVAL_MS=300000
# KAFKA_FETCH_MIN_BYTES=1
# KAFKA_FETCH_MAX_WAIT_MS=500
# KAFKA_MAX_PARTITION_FETCH_BYTES=1048576

# Consumer poison-pill handling
# KAFKA_MAX_MESSAGE_RETRIES=3
# DEAD_LETTER_KEY=stats:dead_letter
# DEAD_LETTER_MAX_LEN=1000

# Redis stats TTL (rolling window in seconds, default: 24h)
# STATS_TTL_SECONDS=86400
